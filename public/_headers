/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://api.mmkorea.com; connect-src 'self' https://api.mmkorea.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://*.kcp.co.kr; object-src 'none'
